{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "AzureAd": {
    "Instance": "https://login.microsoftonline.com/",
    "TenantId": "common",
    "ClientId": "REPLACE_WITH_LANDING_APP_CLIENT_ID",
    "CallbackPath": "/signin-oidc"
  },
  "Landing": {
    "RequireAuthentication": true
  },
  "Fulfillment": {
    "BaseUrl": "https://marketplaceapi.microsoft.com/api",
    "ApiVersion": "2018-08-31",
    "Webhook": {
      "Audience": "REPLACE_WITH_PUBLISHER_APP_CLIENT_ID",
      "ExpectedAppId": "20e940b3-4c07-4bc1-a733-45f7c7a3d0e3",
      "MetadataAddress": "https://login.microsoftonline.com/common/v2.0/.well-known/openid-configuration",
      "RequireSignedToken": true
    }
  },
  "Database": {
    "Provider": "Sqlite",
    "ConnectionString": "Data Source=saas-agent-sample.db"
  }
}
