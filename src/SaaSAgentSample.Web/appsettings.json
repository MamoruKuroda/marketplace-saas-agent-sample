{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "AzureAd": {
    "Instance": "https://login.microsoftonline.com/",
    "TenantId": "common",
    "ClientId": "REPLACE_WITH_LANDING_APP_CLIENT_ID",
    "CallbackPath": "/signin-oidc"
  },
  "Landing": {
    "RequireAuthentication": true
  },
  "Fulfillment": {
    "BaseUrl": "https://marketplaceapi.microsoft.com/api",
    "ApiVersion": "2018-08-31"
  },
  "Database": {
    "Provider": "Sqlite",
    "ConnectionString": "Data Source=saas-agent-sample.db"
  }
}
