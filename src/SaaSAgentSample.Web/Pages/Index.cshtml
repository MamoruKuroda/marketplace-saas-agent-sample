@page
@model SaaSAgentSample.Web.Pages.IndexModel
@{
    ViewData["Title"] = "Activate your subscription";
    var r = Model.Resolved;
    var sub = r?.Subscription;
}
<h1 class="page-title">Activate your subscription</h1>
<p class="subtitle">Review the plan below, then confirm. Activation starts billing.</p>

@if (User?.Identity?.IsAuthenticated == true)
{
    <p class="muted">Signed in as @User.Identity!.Name</p>
}

@if (Model.IsActivated)
{
    <div class="banner">
        <span class="ico">&#10003;</span>
        <div>
            <strong>Activated.</strong> @Model.Message
            <div style="margin-top:.4rem"><a href="/admin">View all subscriptions in the publisher admin &rarr;</a></div>
        </div>
    </div>
}
else if (r is not null)
{
    <div class="card">
        <h2>Confirm activation</h2>
        <p class="hint">Resolved from your marketplace purchase token.</p>
        <dl class="kv">
            <dt>Subscription</dt><dd>@(r.SubscriptionName ?? sub?.Name)</dd>
            <dt>Offer</dt><dd>@(r.OfferId ?? sub?.OfferId)</dd>
            <dt>Plan</dt><dd>@(r.PlanId ?? sub?.PlanId)</dd>
            <dt>Quantity</dt><dd>@(r.Quantity?.ToString() ?? "—")</dd>
            <dt>Status</dt><dd><span class="badge pending">@sub?.SaasSubscriptionStatus</span></dd>
        </dl>
        <form method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="subscriptionId" value="@(sub?.Id ?? r.Id)" />
            <input type="hidden" name="planId" value="@(r.PlanId ?? sub?.PlanId)" />
            @if (r.Quantity is int q)
            {
                <input type="hidden" name="quantity" value="@q" />
            }
            <button type="submit" class="btn primary">Activate subscription</button>
        </form>
    </div>
}
else
{
    <div class="card"><p class="muted">@(Model.Message ?? "Nothing to show.")</p></div>
}
