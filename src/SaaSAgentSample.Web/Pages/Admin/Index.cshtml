@page "/admin"
@using SaaSAgentSample.Core.Subscriptions
@model SaaSAgentSample.Web.Pages.Admin.IndexModel
@{
    ViewData["Title"] = "Publisher admin — subscriptions";
    static string BadgeClass(SubscriptionState state) => state switch
    {
        SubscriptionState.Subscribed => "subscribed",
        SubscriptionState.Suspended => "suspended",
        SubscriptionState.Unsubscribed => "unsubscribed",
        _ => "pending",
    };
}
<h1 class="page-title">Subscriptions</h1>
<p class="subtitle">Authoritative state store &middot; read-only view. State changes require explicit confirmation on the detail page.</p>

@if (Model.Subscriptions.Count == 0)
{
    <div class="card"><p class="muted">No subscriptions yet. Activate one from a buyer landing link to see it here.</p></div>
}
else
{
    <div class="table-wrap">
        <table>
            <thead>
                <tr>
                    <th>Marketplace subscription</th>
                    <th>Name</th>
                    <th>Offer</th>
                    <th>Plan</th>
                    <th>State</th>
                    <th>Updated (UTC)</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var s in Model.Subscriptions)
                {
                    <tr>
                        <td><code>@s.MarketplaceSubscriptionId</code></td>
                        <td>@(string.IsNullOrEmpty(s.Name) ? "—" : s.Name)</td>
                        <td>@s.OfferId</td>
                        <td>@s.PlanId</td>
                        <td><span class="badge @BadgeClass(s.State)">@s.State</span></td>
                        <td class="muted">@s.UpdatedAt.UtcDateTime.ToString("u")</td>
                        <td><a href="/admin/@s.Id">Details</a></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
