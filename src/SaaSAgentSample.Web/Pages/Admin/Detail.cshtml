@page "/admin/{id:guid}"
@using SaaSAgentSample.Core.Subscriptions
@model SaaSAgentSample.Web.Pages.Admin.DetailModel
@{
    ViewData["Title"] = "Subscription detail";
    var s = Model.Subscription;
    static string BadgeClass(SubscriptionState state) => state switch
    {
        SubscriptionState.Subscribed => "subscribed",
        SubscriptionState.Suspended => "suspended",
        SubscriptionState.Unsubscribed => "unsubscribed",
        _ => "pending",
    };
}
<p><a class="back-link" href="/admin">&larr; All subscriptions</a></p>
<h1 class="page-title">Subscription detail</h1>

@if (Model.Message is not null)
{
    <div class="notice">@Model.Message</div>
}

@if (s is not null)
{
    <div class="card" style="max-width:640px">
        <dl class="kv">
            <dt>Marketplace subscription</dt><dd><code>@s.MarketplaceSubscriptionId</code></dd>
            <dt>Name</dt><dd>@(string.IsNullOrEmpty(s.Name) ? "—" : s.Name)</dd>
            <dt>Offer</dt><dd>@s.OfferId</dd>
            <dt>Plan</dt><dd>@s.PlanId</dd>
            <dt>State</dt><dd><span class="badge @BadgeClass(s.State)">@s.State</span></dd>
            <dt>Created (UTC)</dt><dd>@s.CreatedAt.UtcDateTime.ToString("u")</dd>
            <dt>Updated (UTC)</dt><dd>@s.UpdatedAt.UtcDateTime.ToString("u")</dd>
        </dl>

        @if (Model.CanActivate)
        {
            <form method="post" action="?handler=Activate">
                @Html.AntiForgeryToken()
                <p class="hint">Activation calls the Fulfillment Activate API and starts billing. Confirm before proceeding.</p>
                <button type="submit" class="btn primary">Activate subscription</button>
            </form>
        }
        else
        {
            <p class="muted">No publisher actions from the <strong>@s.State</strong> state.</p>
            <p class="hint" style="margin-top:.4rem">
                From here, changes (Suspend, Reinstate, Change plan, Unsubscribe) are <strong>Microsoft-initiated</strong>
                and arrive as a connection webhook — this app validates it and updates state. In this demo, trigger them
                from the emulator's <strong>Subscriptions</strong> tab, then refresh this page.
            </p>
        }
    </div>
}
