@page "/admin/{id:guid}"
@using SaaSAgentSample.Core.Subscriptions
@model SaaSAgentSample.Web.Pages.Admin.DetailModel
@{
    ViewData["Title"] = L["Subscription detail"].Value;
    var s = Model.Subscription;
    static string BadgeClass(SubscriptionState state) => state switch
    {
        SubscriptionState.Subscribed => "subscribed",
        SubscriptionState.Suspended => "suspended",
        SubscriptionState.Unsubscribed => "unsubscribed",
        _ => "pending",
    };
}
<p><a class="back-link" href="/admin">@L["← All subscriptions"]</a></p>
<h1 class="page-title">@L["Subscription detail"]</h1>

@if (Model.Message is not null)
{
    <div class="notice">@Model.Message</div>
}

@if (s is not null)
{
    <div class="card" style="max-width:640px">
        <dl class="kv">
            <dt>@L["Marketplace subscription"]</dt><dd><code>@s.MarketplaceSubscriptionId</code></dd>
            <dt>@L["Name"]</dt><dd>@(string.IsNullOrEmpty(s.Name) ? "—" : s.Name)</dd>
            <dt>@L["Offer"]</dt><dd>@s.OfferId</dd>
            <dt>@L["Plan"]</dt><dd>@s.PlanId</dd>
            <dt>@L["State"]</dt><dd><span class="badge @BadgeClass(s.State)">@s.State</span></dd>
            <dt>@L["Created (UTC)"]</dt><dd>@s.CreatedAt.UtcDateTime.ToString("u")</dd>
            <dt>@L["Updated (UTC)"]</dt><dd>@s.UpdatedAt.UtcDateTime.ToString("u")</dd>
        </dl>

        @if (Model.CanActivate)
        {
            <form method="post" action="?handler=Activate">
                @Html.AntiForgeryToken()
                <p class="hint">@L["Activation calls the Fulfillment Activate API and starts billing. Confirm before proceeding."]</p>
                <button type="submit" class="btn primary">@L["Activate subscription"]</button>
            </form>
        }
        else
        {
            <p class="muted">@L["No publisher actions available from the current state ({0}).", s.State]</p>
            <p class="hint" style="margin-top:.4rem">
                @L["From here, changes (Suspend, Reinstate, Change plan, Unsubscribe) are Microsoft-initiated and arrive as a connection webhook — this app validates it and updates state. In this demo, trigger them from the emulator's Subscriptions tab, then refresh this page."]
            </p>
        }
    </div>
}
